        },
        "schema": "IdeTerminalRequestObservationV1"
      },
      "permission": "dangerous",
      "ref": "ide-adapter://phase8/ide.terminal.request",
      "schemaVersion": "ide-adapter-capability-v1",
      "sideEffectRisk": "process_or_filesystem_mutation"
    },
    {
      "approvalRequired": false,
      "category": "human_gate",
      "executionMode": "contract_only",
      "externalSideEffectAllowed": false,
      "implemented": false,
      "inputContract": {
        "properties": {
          "approvalPoint": "string:approval-point",
          "runRef": "string:run-ref"
        },
        "required": [
          "runRef",
          "approvalPoint"
        ],
        "schema": "IdeApprovalRequestInputV1"
      },
      "name": "ide.approval.request",
      "observationContract": {
        "produces": [
          "approvalDecisionRef"
        ],
        "properties": {
          "approvalDecisionRef": "string:human-decision-ref"
        },
        "schema": "IdeApprovalObservationV1"
      },
      "permission": "read",
      "ref": "ide-adapter://phase8/ide.approval.request",
      "schemaVersion": "ide-adapter-capability-v1",
      "sideEffectRisk": "approval_prompt_only"
    }
  ],
  "id": "phase8-static-ide-adapter-contract",
  "mode": "static_contract_only",
  "phase": "phase8",
  "policy": {
    "dangerousCapabilitiesRequireApproval": true,
    "externalSideEffectsAllowed": false,
    "realIdeExecutionAllowed": false,
    "terminalExecutionAllowed": false,
    "workspaceMutationAllowed": false
  },
  "schemaVersion": "ide-adapter-contract-v1",
  "scope": "ide_adapter_boundary",
  "workspaceObservationContract": {
    "allowedObservationKinds": [
      "workspace_snapshot"
    ],
    "requiredBindings": [
      "workspaceRef",
      "sourceArtifacts",
      "capabilityRef"
    ],
    "schemaVersion": "workspace-observation-v1",
    "taskVerdictOwner": "verifier-runtime-v1"
  }
}
