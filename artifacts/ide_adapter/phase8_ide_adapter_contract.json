        ],
        "schema": "IdeDiffViewOpenInputV1"
      },
      "name": "ide.diff_view.open",
      "observationContract": {
        "produces": [
          "diffViewRef"
        ],
        "properties": {
          "diffViewRef": "string:observation-ref"
        },
        "schema": "IdeUiActionObservationV1"
      },
      "permission": "write",
      "ref": "ide-adapter://phase8/ide.diff_view.open",
      "schemaVersion": "ide-adapter-capability-v1",
      "sideEffectRisk": "ide_ui_state_change"
    },
    {
      "approvalRequired": true,
      "category": "terminal",
      "executionMode": "contract_only",
      "externalSideEffectAllowed": false,
      "implemented": false,
      "inputContract": {
        "properties": {
          "command": "string:approved-command",
