      "sideEffectRisk": "isolated_environment_lifecycle"
    },
    {
      "approvalRequired": false,
      "category": "trajectory",
      "executionMode": "contract_only",
      "externalSideEffectAllowed": false,
      "implemented": false,
      "inputContract": {
        "properties": {
          "eventRef": "string:run-event-ref",
