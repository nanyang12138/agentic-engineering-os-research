        },
        "required": [
          "eventRef",
          "observationRef"
        ],
        "schema": "TrajectoryRecordInputV1"
      },
      "name": "trajectory.record",
      "observationContract": {
        "produces": [
          "trajectoryObservation"
        ],
        "properties": {
          "trajectoryObservation": "trajectory-observation-v1"
        },
        "schema": "TrajectoryObservationV1"
      },
      "permission": "read",
      "ref": "computer-runtime://phase7/trajectory.record",
      "schemaVersion": "computer-runtime-capability-v1",
      "sideEffectRisk": "observation_capture_only"
    }
  ],
  "id": "phase7-static-computer-runtime-contract",
  "mode": "static_contract_only",
  "phase": "phase7",
  "policy": {
    "dangerousCapabilitiesRequireApproval": true,
    "externalSideEffectsAllowed": false,
    "realProviderExecutionAllowed": false
  },
  "schemaVersion": "computer-runtime-adapter-contract-v1",
  "scope": "computer_runtime_adapter_boundary",
  "trajectoryContract": {
    "allowedObservationKinds": [
      "trajectory_event"
    ],
    "requiredBindings": [
      "runId",
      "eventRef",
      "evidenceId",
      "capabilityRef"
    ],
    "schemaVersion": "trajectory-observation-v1",
    "taskVerdictOwner": "verifier-runtime-v1"
  }
}
